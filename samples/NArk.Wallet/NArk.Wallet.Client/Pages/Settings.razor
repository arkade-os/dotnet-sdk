@page "/settings"
@inject ArkWalletService Ark
@inject WalletState State
@inject IJSRuntime JS
@using NArk.Wallet.Client.Services

<div class="page-header">
    <a href="./" class="back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <span class="page-title">Settings</span>
</div>

<div class="px-20">
    @if (_loading)
    {
        <div class="flex-col gap-12">
            <div class="skeleton" style="height:80px;border-radius:14px;"></div>
            <div class="skeleton" style="height:80px;border-radius:14px;"></div>
        </div>
    }
    else if (State.ActiveWalletId is null)
    {
        <div class="empty-state">
            <p>No wallet created yet</p>
        </div>
    }
    else
    {
        <!-- Wallet Info -->
        <div class="section-header" style="padding:0;">
            <span class="section-title">Wallet</span>
        </div>

        <div class="glass-card mb-16 mt-12">
            <p class="input-label">Wallet ID</p>
            <div class="address-display" style="margin-bottom:8px;" @onclick="@(() => CopyToClipboard(State.ActiveWalletId!))">
                @State.ActiveWalletId
            </div>
            <button class="btn btn-sm btn-secondary" @onclick="@(() => CopyToClipboard(State.ActiveWalletId!))">
                @(_copiedField == "walletId" ? "Copied!" : "Copy")
            </button>
        </div>

        @if (_arkAddress is not null)
        {
            <div class="glass-card mb-16">
                <p class="input-label">Ark Address</p>
                <div class="address-display" style="margin-bottom:8px;">@_arkAddress</div>
                <div style="display:flex;gap:8px;">
                    <button class="btn btn-sm btn-secondary" @onclick="@(() => CopyToClipboard(_arkAddress!, "ark"))">
                        @(_copiedField == "ark" ? "Copied!" : "Copy")
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="ToggleArkQr">
                        @(_showArkQr ? "Hide QR" : "Show QR")
                    </button>
                </div>
                @if (_showArkQr)
                {
                    <div class="qr-container mt-12" style="margin:12px auto 0;">
                        @((MarkupString)QrCodeHelper.GenerateSvg(_arkAddress))
                    </div>
                }
            </div>
        }

        @if (_boardingAddress is not null)
        {
            <div class="glass-card mb-16">
                <p class="input-label">Boarding Address</p>
                <div class="address-display" style="margin-bottom:8px;">@_boardingAddress</div>
                <button class="btn btn-sm btn-secondary" @onclick="@(() => CopyToClipboard(_boardingAddress!, "boarding"))">
                    @(_copiedField == "boarding" ? "Copied!" : "Copy")
                </button>
            </div>
        }

        <!-- Server Info -->
        @if (_serverNetwork is not null)
        {
            <div class="section-header mt-24" style="padding:0;">
                <span class="section-title">Server</span>
            </div>

            <div class="glass-card mb-16 mt-12">
                <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                    <span class="text-secondary" style="font-size:13px;">Network</span>
                    <span style="font-size:13px;font-weight:500;">@_serverNetwork</span>
                </div>
                @if (_serverPubkey is not null)
                {
                    <div style="margin-bottom:8px;">
                        <span class="text-secondary" style="font-size:13px;">Server Pubkey</span>
                        <div class="address-display" style="font-size:10px;margin-top:4px;">@_serverPubkey</div>
                    </div>
                }
            </div>
        }

        <!-- Coins (VTXOs) -->
        <div class="section-header mt-24" style="padding:0;">
            <span class="section-title">Coins (VTXOs)</span>
            @if (_vtxos is not null)
            {
                <span class="text-secondary" style="font-size:12px;">@_vtxos.Count total</span>
            }
        </div>

        @if (_vtxos is null)
        {
            <div class="skeleton mt-12" style="height:60px;"></div>
        }
        else if (_vtxos.Count == 0)
        {
            <div class="empty-state">
                <div class="glass-card">
                    <p>No coins yet</p>
                </div>
            </div>
        }
        else
        {
            <div class="flex-col gap-12 mt-12">
                @foreach (var vtxo in _vtxos)
                {
                    <div class="glass-card" style="padding:12px 14px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <div>
                                <p style="font-size:14px;font-weight:600;font-family:var(--font-mono);">
                                    @vtxo.Amount.ToString("N0") <span class="text-secondary" style="font-weight:400;font-size:12px;">sats</span>
                                </p>
                                <p class="text-secondary" style="font-size:11px;font-family:var(--font-mono);">
                                    @vtxo.TransactionId[..16]...
                                </p>
                            </div>
                            <span class="pill @(vtxo.IsSpent() ? "pill-danger" : "pill-success")" style="font-size:9px;">
                                @(vtxo.IsSpent() ? "SPENT" : "LIVE")
                            </span>
                        </div>
                        @if (vtxo.ExpiresAt is not null)
                        {
                            <p class="text-secondary" style="font-size:11px;margin-top:4px;">
                                Expires: @vtxo.ExpiresAt.Value.LocalDateTime.ToString("MMM d, HH:mm")
                            </p>
                        }
                    </div>
                }
            </div>
        }

        <!-- Danger Zone -->
        <div class="section-header mt-24" style="padding:0;">
            <span class="section-title" style="color:var(--arkade-red);">Danger Zone</span>
        </div>

        <div class="glass-card mt-12 mb-24" style="border-color:rgba(224,82,82,0.2);">
            <p class="text-secondary mb-12" style="font-size:12px;">
                Deleting your wallet removes it from this device. Make sure you have backed up your secret.
            </p>
            @if (_confirmDelete)
            {
                <div style="display:flex;gap:8px;">
                    <button class="btn btn-sm" style="background:var(--arkade-red);color:white;flex:1;" @onclick="DeleteWallet">
                        Confirm Delete
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="@(() => _confirmDelete = false)">
                        Cancel
                    </button>
                </div>
            }
            else
            {
                <button class="btn btn-sm btn-secondary" style="color:var(--arkade-red);border-color:rgba(224,82,82,0.3);"
                        @onclick="@(() => _confirmDelete = true)">
                    Delete Wallet
                </button>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _arkAddress;
    private string? _boardingAddress;
    private string? _serverNetwork;
    private string? _serverPubkey;
    private IReadOnlyCollection<ArkVtxo>? _vtxos;
    private string? _copiedField;
    private bool _showArkQr;
    private bool _confirmDelete;

    protected override async Task OnInitializedAsync()
    {
        if (State.ActiveWalletId is not null)
        {
            try
            {
                var receiveTask = Ark.GetReceiveInfo(State.ActiveWalletId);
                var vtxoTask = Ark.GetVtxos(State.ActiveWalletId, take: 100);
                var serverTask = Ark.GetServerInfo();

                await Task.WhenAll(receiveTask, vtxoTask, serverTask);

                var (ark, boarding) = receiveTask.Result;
                _arkAddress = ark;
                _boardingAddress = boarding;
                _vtxos = vtxoTask.Result;

                var info = serverTask.Result;
                _serverNetwork = info.Network?.Name ?? "Unknown";
                _serverPubkey = info.SignerKey?.ToString();
            }
            catch { }
        }
        _loading = false;
    }

    private async Task CopyToClipboard(string text, string? field = null)
    {
        await JS.InvokeVoidAsync("arkade.copyToClipboard", text);
        _copiedField = field ?? "walletId";
        StateHasChanged();
        await Task.Delay(2000);
        _copiedField = null;
    }

    private void ToggleArkQr() => _showArkQr = !_showArkQr;

    private async Task DeleteWallet()
    {
        if (State.ActiveWalletId is not null)
        {
            await Ark.DeleteWallet(State.ActiveWalletId);
            State.SetActiveWallet(null);
            _confirmDelete = false;
        }
    }
}
